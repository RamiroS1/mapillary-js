{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps --ignore-scripts",
  "buildCommand": "npm run build && mkdir -p public && cp -r dist public/",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["examples/custom-data/**", "dist/**", "node_modules/three/**"]
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
