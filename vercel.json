{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps --ignore-scripts",
  "buildCommand": "npm run build && mkdir -p public && cp -r dist public/ && mkdir -p api/dist && cp -r dist/* api/dist/",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "examples/custom-data/**",
          "dist/**",
          "public/**",
          "node_modules/three/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}